modules = ["python-3.12", "web", "nix"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"
packages = ["libxcrypt", "postgresql"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "redis-server --daemonize yes --port 6379 --loglevel warning; sleep 1 && cd backend && python3 -m uvicorn app.main:app --host 0.0.0.0 --port 5000 --reload"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 6379
externalPort = 3000

[deployment]
deploymentTarget = "autoscale"
run = ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "5000", "--workers", "4"]

[userenv]

[userenv.shared]
APP_ENV = "development"
APP_VERSION = "0.9.0"
DEBUG = "false"
LOG_LEVEL = "INFO"
LOG_FORMAT = "json"
REDIS_URL = "redis://localhost:6379/0"
COLLECTOR_INTERVAL_SECONDS = "5"
COLLECTOR_ENABLED = "true"
SCANNER_INTERVAL_SECONDS = "300"
SCANNER_ENABLED = "true"
SCANNER_RUN_ON_STARTUP = "true"
UNIVERSE_SYNC_INTERVAL_SECONDS = "60"
UNIVERSE_SYNC_ENABLED = "true"
UNIVERSE_SYNC_RUN_ON_STARTUP = "true"
PRICE_REFRESH_SECONDS = "10"
PRICE_REFRESH_ENABLED = "true"
PRICE_REFRESH_RUN_ON_STARTUP = "true"
SIGNAL_ENGINE_ENABLED = "true"
SIGNAL_ENGINE_INTERVAL_SECONDS = "10"
SIGNAL_ENGINE_RUN_ON_STARTUP = "true"
OPPORTUNITY_ENGINE_ENABLED = "true"
OPPORTUNITY_ENGINE_INTERVAL_SECONDS = "30"
OPPORTUNITY_ENGINE_RUN_ON_STARTUP = "true"
STRATEGY_ENGINE_ENABLED = "true"
STRATEGY_ENGINE_INTERVAL_SECONDS = "60"
STRATEGY_ENGINE_RUN_ON_STARTUP = "true"
EXECUTION_ENGINE_ENABLED = "true"
EXECUTION_ENGINE_INTERVAL_SECONDS = "30"
EXECUTION_ENGINE_RUN_ON_STARTUP = "true"
EXECUTION_PAPER_MODE = "true"
POSITION_TRACKING_INTERVAL_SECONDS = "30"
RISK_ENGINE_ENABLED = "true"
RISK_ENGINE_INTERVAL_SECONDS = "15"
RISK_ENGINE_RUN_ON_STARTUP = "true"
