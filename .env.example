# ── Application ─────────────────────────────────────────────────────────────
APP_ENV=development
APP_VERSION=0.3.0
DEBUG=false
LOG_LEVEL=INFO
LOG_FORMAT=json

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/polymarket
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=polymarket

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Price Collector (Sprint 2) ───────────────────────────────────────────────
COLLECTOR_INTERVAL_SECONDS=5
COLLECTOR_ENABLED=true

# ── Market Scanner (Sprint 3) ────────────────────────────────────────────────
SCANNER_INTERVAL_SECONDS=300
SCANNER_ENABLED=true
SCANNER_RUN_ON_STARTUP=true

# ── External APIs (Sprint 4+) ────────────────────────────────────────────────
# BINANCE_API_KEY=
# BINANCE_API_SECRET=
# POLYMARKET_API_KEY=
# POLYMARKET_PRIVATE_KEY=
# ETHEREUM_RPC_URL=
