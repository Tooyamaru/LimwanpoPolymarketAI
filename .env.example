# ── Application ─────────────────────────────────────────────────────────────
APP_ENV=development
APP_VERSION=0.2.0
DEBUG=false
LOG_LEVEL=INFO
LOG_FORMAT=json

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/polymarket
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=polymarket

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Collector ────────────────────────────────────────────────────────────────
COLLECTOR_INTERVAL_SECONDS=5
COLLECTOR_ENABLED=true

# ── External APIs (Sprint 3+) ────────────────────────────────────────────────
# BINANCE_API_KEY=
# BINANCE_API_SECRET=
# POLYMARKET_API_KEY=
# POLYMARKET_PRIVATE_KEY=
# ETHEREUM_RPC_URL=
